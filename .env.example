# ===== Supabase (backend, runtime) =====
# Required for user auth and activity logging
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===== Frontend build args (Vite) =====
# IMPORTANT: these are baked into the static frontend bundle at `docker compose
# build` time, not read at container runtime. They must be set here (or in the
# shell env) BEFORE building the image, and rebuilt whenever they change.
# VITE_API_BASE_URL must be the address the *user's browser* can reach the
# backend at (e.g. http://your-server-host:5001), not localhost.
VITE_API_BASE_URL=http://your-server-host:5001
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
# Vision model untuk membaca gambar/grafis (PNG, JPG, WEBP)
# Gunakan model yang sama atau pisah jika provider berbeda
LLM_VISION_MODEL_NAME=qwen-vl-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here